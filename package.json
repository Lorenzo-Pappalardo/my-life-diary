{
	"name": "my-life-logbook",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint --ext .js,.ts,.svelte .",
		"lint:fix": "prettier --write . && eslint --ext .js,.ts,.svelte --fix .",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"ci": "pnpm install --frozen-lockfile && pnpm lint && pnpm build",
		"prisma:db:push": "prisma db push",
		"prisma:migrate:dev": "prisma migrate dev",
		"prisma:generate": "prisma generate",
		"import:generate": "tsc --project ./src/import/markdown/tsconfig.json && node ./src/import/markdown/main.js",
		"export:generate": "tsc --project ./src/routes/export/tsconfig.json"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"formsnap": "^2.0.1",
		"pg": "^8.20.0",
		"sveltekit-superforms": "^2.30.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
